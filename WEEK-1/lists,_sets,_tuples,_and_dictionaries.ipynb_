{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyN+C+klqB29hE7iojedbEtm"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-o3Tuj4Hqh91","executionInfo":{"status":"ok","timestamp":1783915904841,"user_tz":-330,"elapsed":14,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"37e6214f-ce2c-4c76-dbff-e2b31fb8cdf3"},"outputs":[{"output_type":"stream","name":"stdout","text":["Original list: ['apple', 'banana', 'cherry', 'apple']\n","First fruit: apple\n"]}],"source":["# 🔹 1. LISTS\n","\n","fruits = ['apple', 'banana', 'cherry', 'apple']\n","print(\"Original list:\", fruits)\n","\n","# Accessing elements by index\n","print(\"First fruit:\", fruits[0])"]},{"cell_type":"code","source":["# Adding an item\n","fruits.append('orange')\n","print(\"After appending:\", fruits)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nGEgSLdcrStw","executionInfo":{"status":"ok","timestamp":1783915970445,"user_tz":-330,"elapsed":9,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"c98fe8b2-a0de-4cf6-803e-6527f34d6382"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["After appending: ['apple', 'banana', 'cherry', 'apple', 'orange']\n"]}]},{"cell_type":"code","source":["# Removing an item\n","fruits.remove('banana')\n","print(\"After removing banana:\", fruits)\n","# List length\n","print(\"Number of fruits:\", len(fruits))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eRvMIh_4rcmI","executionInfo":{"status":"ok","timestamp":1783916022834,"user_tz":-330,"elapsed":49,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"21a1412c-c7b8-4486-9db8-daec04d4ebe7"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["After removing banana: ['apple', 'cherry', 'apple', 'orange']\n","Number of fruits: 4\n"]}]},{"cell_type":"code","source":["# 🔹 2. TUPLES\n","dimensions = (10, 20, 30)\n","print(\"Tuple:\", dimensions)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"HrXpMIP3rr1J","executionInfo":{"status":"ok","timestamp":1783916075414,"user_tz":-330,"elapsed":45,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"1322cfb9-bbb1-4dec-f133-415851c0115d"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Tuple: (10, 20, 30)\n"]}]},{"cell_type":"code","source":["# Accessing elements\n","print(\"Second element:\", dimensions[1])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sMCfVaR5ry35","executionInfo":{"status":"ok","timestamp":1783916109562,"user_tz":-330,"elapsed":10,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"62b3ff45-e17c-42fa-e427-edde528e1055"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Second element: 20\n"]}]},{"cell_type":"code","source":["# 3. SETS\n","unique_numbers = {1, 2, 3, 2, 1}\n","print(\"Set (no duplicates):\", unique_numbers)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_OxjCLDvr9Fp","executionInfo":{"status":"ok","timestamp":1783916173972,"user_tz":-330,"elapsed":11,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"a9e543f4-66a7-47ce-ad1a-dd394b67aff3"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Set (no duplicates): {1, 2, 3}\n"]}]},{"cell_type":"code","source":["# Adding elements\n","unique_numbers.add(4)\n","print(\"After adding 4:\", unique_numbers)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZA38Lll4sObi","executionInfo":{"status":"ok","timestamp":1783916215655,"user_tz":-330,"elapsed":14,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"564105b1-0d36-4dc7-e98c-886d8606d8d4"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["After adding 4: {1, 2, 3, 4}\n"]}]},{"cell_type":"code","source":["#Removing elements\n","unique_numbers.remove(2)\n","print(\"After removing 2:\",unique_numbers)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_pziDCLesaqQ","executionInfo":{"status":"ok","timestamp":1783916448034,"user_tz":-330,"elapsed":53,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"319b5c84-fa51-47d4-f52c-f85bbffeb9b6"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["After removing 2: {1, 3, 4}\n"]}]},{"cell_type":"code","source":["# Set operations\n","set_a = {1, 2, 3}\n","set_b = {3, 4, 5}\n","print(\"Union:\", set_a | set_b)\n","print(\"Intersection:\", set_a & set_b)\n","print(\"Difference (A - B):\", set_a - set_b)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eAnCj81btOOS","executionInfo":{"status":"ok","timestamp":1783916657073,"user_tz":-330,"elapsed":11,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"1022970e-33d8-4a87-d684-ca39bc77a323"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["Union: {1, 2, 3, 4, 5}\n","Intersection: {3}\n","Difference (A - B): {1, 2}\n"]}]},{"cell_type":"code","source":["# 4.DICTIONARIES\n","student = {\n","    'name': 'Alice',\n","    'age': 21,\n","    'course': 'Python'\n","}\n","print(\"Dictionary:\", student)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"d8OQrkndti30","executionInfo":{"status":"ok","timestamp":1783916646095,"user_tz":-330,"elapsed":12,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"4f6cfe39-da8b-49ce-aba0-3b14816b659c"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary: {'name': 'Alice', 'age': 21, 'course': 'Python'}\n"]}]},{"cell_type":"code","source":["#Access value by key\n","print(\"Student name\",student['name'])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Ud2Igv5MuDtM","executionInfo":{"status":"ok","timestamp":1783916722494,"user_tz":-330,"elapsed":13,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"3e59b857-2e49-4adb-a34e-34fe9ab4ac5a"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["Student name Alice\n"]}]},{"cell_type":"code","source":["# Add or update value\n","student['grade'] = 'A'\n","print(\"After adding grade:\", student)\n","# Remove a key\n","del student['age']\n","print(\"After deleting age:\", student)\n","# Loop through dictionary\n","for key, value in student.items():\n","    print(f\"{key}: {value}\")\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qIjAEsD4uQjD","executionInfo":{"status":"ok","timestamp":1783916765275,"user_tz":-330,"elapsed":11,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"1fb03bc2-12d1-4307-cc7b-a034dc204c8b"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["After adding grade: {'name': 'Alice', 'age': 21, 'course': 'Python', 'grade': 'A'}\n","After deleting age: {'name': 'Alice', 'course': 'Python', 'grade': 'A'}\n","name: Alice\n","course: Python\n","grade: A\n"]}]},{"cell_type":"code","source":["# Bonus: Dictionary from two lists using zip()\n","keys = ['id', 'name', 'marks']\n","values = [101, 'John', 88]\n","student_info = dict(zip(keys, values))\n","print(\"Student Info from zip:\", student_info)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"8NJOpmTxubNr","executionInfo":{"status":"ok","timestamp":1783916973858,"user_tz":-330,"elapsed":44,"user":{"displayName":"NAGULA RAKSHITHA","userId":"06863837952974249689"}},"outputId":"c390f400-c5e1-4650-97b7-ec5f955f0f40"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["Student Info from zip: {'id': 101, 'name': 'John', 'marks': 88}\n"]}]}]}
